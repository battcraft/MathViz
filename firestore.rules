rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net default deny
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Helper Primitives
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }

    // Validation Blueprint for UserStats
    function isValidUserStats(data) {
      return data.get('userId', '') is string 
        && data.get('userId', '') == request.auth.uid // No status or identity spoofing
        && (data.get('xp', 0) is int || data.get('xp', 0) is float) && data.get('xp', 0) >= 0
        && (data.get('streak', 0) is int || data.get('streak', 0) is float) && data.get('streak', 0) >= 0
        && (data.get('lastActiveDate', null) == null || data.get('lastActiveDate', null) is string)
        && (data.get('screensViewed', null) == null || data.get('screensViewed', null) is list)
        && (data.get('completedScreens', null) == null || data.get('completedScreens', null) is list)
        && (data.get('badges', null) == null || data.get('badges', null) is list)
        && (data.get('quizScores', null) == null || data.get('quizScores', null) is list);
    }

    // Match statement for the users collection
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId); // Query enforcer
      
      allow create: if isOwner(userId) 
        && incoming().keys().hasAll(['userId', 'xp', 'streak']) 
        && incoming().keys().size() >= 3
        && isValidUserStats(incoming());
        
      allow update: if isOwner(userId)
        && isValidUserStats(incoming())
        && incoming().get('userId', '') == existing().get('userId', '') // Immutable field
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['xp', 'streak', 'lastActiveDate', 'screensViewed', 'completedScreens', 'badges', 'quizScores'])
        );
        
      allow delete: if isOwner(userId);
    }

    // Helper validation for Quiz
    function isValidQuiz(data) {
      return data.id is string
        && data.topicId is string
        && data.subtopicId is string
        && data.difficulty is string
        && data.questions is list
        && (data.createdAt == null || data.createdAt is string);
    }

    // Helper validation for Story
    function isValidStory(data) {
      return data.id is string
        && data.topicId is string
        && data.subtopicId is string
        && data.slides is list
        && (data.createdAt == null || data.createdAt is string);
    }

    match /quizzes/{quizId} {
      allow read: if true;
      allow create, update: if isSignedIn() && isValidQuiz(incoming());
      allow delete: if false;
    }

    match /stories/{storyId} {
      allow read: if true;
      allow create, update: if isSignedIn() && isValidStory(incoming());
      allow delete: if false;
    }
  }
}
