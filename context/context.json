      "difficulty_breakdown": {
        "beginner": {
          "class": "Class 6",
          "chapters": ["NCERT Ch 4: Basic Geometrical Ideas"],
          "subtopics": ["geom_bindu", "geom_rekha", "geom_khand", "geom_kiran", "geom_shikhar"],
          "question_style": "Recall shapes, name objects, count sides"
        },
        "intermediate": {
          "class": "Class 7",
          "chapters": ["NCERT Ch 5: Lines & Angles", "Ch 6: Triangles"],
          "subtopics": ["geom_bindu", "geom_rekha", "geom_khand", "geom_kiran", "geom_shikhar"],
          "question_style": "Apply angle properties, classify triangles"
        },
        "expert": {
          "class": "Class 8",
          "chapters": ["NCERT Ch 3: Quadrilaterals", "Ch 9: Mensuration"],
          "subtopics": ["geom_bindu", "geom_rekha", "geom_khand", "geom_kiran", "geom_shikhar"],
          "question_style": "Prove properties, calculate area, 3D reasoning"
        }
      }
    },
    {
      "id": "maxmin",
      "name": "Max, Min & Range (Data Handling)",
      "description": "Statistical measures — maximum, minimum, range of data sets",
      "icon": "📊",
      "difficulty_breakdown": {
        "beginner": {
          "class": "Class 6",
          "chapters": ["NCERT Ch 9: Data Handling"],
          "subtopics": ["maxmin_max", "maxmin_min", "maxmin_range"],
          "question_style": "Find max/min from list, calculate range"
        },
        "intermediate": {
          "class": "Class 7",
          "chapters": ["NCERT Ch 3: Data Handling"],
          "subtopics": ["maxmin_max", "maxmin_min", "maxmin_range"],
          "question_style": "Mean, median, mode alongside max/min"
        },
        "expert": {
          "class": "Class 8",
          "chapters": ["NCERT Ch 4: Data Handling"],
          "subtopics": ["maxmin_max", "maxmin_min", "maxmin_range"],
          "question_style": "Histograms, pie charts, probability with range"
        }
      }
    },
    {
      "id": "compare",
      "name": "Comparing Numbers",
      "description": "Number comparison, decimals, rounding, place value, ordering",
      "icon": "🔢",
      "difficulty_breakdown": {
        "beginner": {
          "class": "Class 6",
          "chapters": ["NCERT Ch 1: Knowing Our Numbers", "Ch 8: Decimals"],
          "subtopics": ["compare_basics", "compare_decimals", "compare_rounding", "compare_place", "compare_order"],
          "question_style": "Compare large numbers, basic decimal comparison, rounding"
        },
        "intermediate": {
          "class": "Class 7",
          "chapters": ["NCERT Ch 1: Integers", "Ch 2: Fractions", "Ch 9: Rational Numbers"],
          "subtopics": ["compare_basics", "compare_decimals", "compare_rounding", "compare_place", "compare_order"],
          "question_style": "Negative number comparison, unlike fractions, rational numbers"
        },
        "expert": {
          "class": "Class 8",
          "chapters": ["NCERT Ch 1: Rational Numbers", "Ch 10: Exponents", "Ch 11: Proportion"],
          "subtopics": ["compare_basics", "compare_decimals", "compare_rounding", "compare_place", "compare_order"],
          "question_style": "Dense set between numbers, exponents comparison, scientific notation"
        }
      }
    }
